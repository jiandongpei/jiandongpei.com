---
import BaseLayout from "@layouts/BaseLayout.astro";
import Card from "@components/Card.astro";
import { getCollection } from 'astro:content';
const title = 'Insights';
const description = 'Essays for post‑go‑live SAP BTP extension problems where architecture — not just implementation — is under question.';
const items = await getCollection('insights');
const records = items.map(i => ({ slug: i.slug, ...i.data }));
const featured = records.filter(r => r.featured);
const visibleRecords = records.filter(r => r.slug !== 'placeholder');
const archive = visibleRecords
  .filter(r => !r.featured)
  .map(r => ({...r, sortDate: r.published ?? r.date ?? ''}))
  .toSorted((a, b) => (a.sortDate > b.sortDate ? -1 : 1));
// Fixed boundary ordering aligned with the model
const boundaryOrder = ['Runtime','Identity','Tenant','Data','Integration','Lifecycle'];
const boundariesSet = new Set(visibleRecords.map(r => r.boundary).filter(b => b && b !== 'Boundary Model'));
const boundaries = boundaryOrder.filter(b => boundariesSet.has(b));
const byBoundary = Object.fromEntries(boundaries.map(b => [b, visibleRecords.filter(r => r.boundary === b)
  .map(r => ({...r, sortDate: r.published ?? r.date ?? ''}))
  .toSorted((a, b) => (a.sortDate > b.sortDate ? -1 : 1))]));
// Roles – curated paths
const rolePaths = [
  { role: 'CIO / CTO', path: 'Boundary Model · Rapid Triage · Verdict' },
  { role: 'Lead Architect', path: 'Identity · Data · Tenant · Lifecycle' },
  { role: 'Program Leadership', path: 'Boundary Audit · Ownership maps' },
  { role: 'Security Architect', path: 'Identity propagation · Trust boundaries' },
  { role: 'Integration Lead', path: 'Jurisdiction · Cross-system contracts' },
];
---
<BaseLayout {title} {description}>
  <section class="stack tight">
    <h1>Insights</h1>
    <p class="measure">Essays for post‑go‑live SAP BTP extension problems where architecture — not just implementation — is under question. References favor structural clarity over news or tutorials.</p>
  </section>

  {featured.length > 0 && (
    <section class="stack">
      <h2>Core essays</h2>
      <div class="stack">
        {featured.map((e) => (
          <Card title={e.title}>
            {e.summary && (<p class="measure">{e.summary}</p>)}
            <a href={`/insights/${e.slug}/`}>Read →</a>
          </Card>
        ))}
      </div>
    </section>
  )}

  {boundaries.length > 0 && (
    <section class="stack">
      <h2>Explore by boundary</h2>
      {boundaries.map((b) => (
        <div class="card">
          <div class="eyebrow">Boundary</div>
          <h3>{b}</h3>
          <ul>
            {byBoundary[b].slice(0, 4).map((e) => (
              <li>
                <a href={`/insights/${e.slug}/`}><strong>{e.title}</strong></a>
                {e.summary && (<span class="muted"> — {e.summary}</span>)}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>
  )}

  <section class="stack">
    <h2>Explore by real‑world symptom</h2>
    <ul>
      <li>Works in Postman; fails behind App Router/Work Zone</li>
      <li>One tenant works; the next exposes the wrong architecture</li>
      <li>The demo passed; the rollout model never existed</li>
      <li>Security hardening reveals an ungovernable architecture</li>
      <li>Every team is locally correct; the system is globally wrong</li>
    </ul>
  </section>

  <section class="stack">
    <h2>Not every failure pattern is a bug</h2>
    <p class="measure">Many recurring SAP BTP extension failures are boundary and jurisdiction failures. Use the patterns to recognize the situation, then move to a decision.</p>
    <p><a href="/failure-patterns/">See failure patterns →</a> · <a href="/implementation-vs-verdict/">Implementation vs verdict →</a></p>
  </section>

  <section class="stack">
    <h2>Read by role</h2>
    <ul>
      {rolePaths.map(r => (<li><strong>{r.role}</strong> → {r.path}</li>))}
    </ul>
  </section>

  <section class="stack">
    <h2>Full archive</h2>
    <ul>
      {archive.map((e) => (
        <li>
          <a href={`/insights/${e.slug}/`}><strong>{e.title}</strong></a>
          {e.published && (<span class="muted"> — {e.published}</span>)}
          {e.subtitle && (<div class="muted">{e.subtitle}</div>)}
          {!e.subtitle && e.summary && (<div class="muted">{e.summary}</div>)}
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
