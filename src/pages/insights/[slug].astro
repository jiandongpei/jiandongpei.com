---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('insights');
  return all.map((entry) => ({ params: { slug: entry.slug } }));
}

const all = await getCollection('insights');
const slug = Astro.params.slug as string;
const entry = all.find((e) => e.slug === slug);
if (!entry) {
  throw new Error(`Essay not found: ${slug}`);
}

const data = entry.data as CollectionEntry<'insights'>['data'];
const { Content } = await entry.render();
const title = data.title;
const description = data.subtitle ?? data.summary ?? 'Essay';
const related = all.filter(e => e.slug !== entry.slug && (
  (data.boundary && e.data.boundary === data.boundary) ||
  (data.audience && e.data.audience === data.audience)
)).slice(0, 5);
---
<BaseLayout {title} {description}>
  <article class="article">
    <header>
      <h1>{data.title}</h1>
      {data.subtitle && (<p class="lede">{data.subtitle}</p>)}
      <div class="meta">
        {data.articleId && (<span>#{data.articleId}</span>)}
        {data.published && (<span>— {data.published}</span>)}
        {data.boundary && (<span class="pill">{data.boundary}</span>)}
        {data.audience && (<span class="pill">{data.audience}</span>)}
        {data.symptom && (<span class="pill">{data.symptom}</span>)}
      </div>
    </header>
    <section class="content">
      <Content />
    </section>
  </article>

  {(() => {
    const sourceHref = data.sourceUrl ?? data.canonicalUrl ?? data.canonical;
    const inferredLabel = sourceHref && sourceHref.includes('linkedin.com') ? 'LinkedIn' : undefined;
    const sourceLabel = data.source ?? inferredLabel;
    if (!sourceLabel && !sourceHref) return null;
    return (
      <section class="stack">
        <h2>Source</h2>
        <p class="measure">
          {sourceLabel}
          {sourceHref && (<>
            : <a href={sourceHref} target="_blank" rel="noopener">{sourceHref}</a>
          </>)}
        </p>
      </section>
    );
  })()}

  

  {related.length > 0 && (
    <section class="stack">
      <h2>Related reading</h2>
      <ul>
        {related.map(r => (
          <li><a href={`/insights/${r.slug}/`}>{r.data.title}</a></li>
        ))}
      </ul>
    </section>
  )}

  

  <section class="stack">
    <h2>Next</h2>
    <ul>
      <li><a href="/when-to-call-me/">See when to bring me in</a></li>
      <li><a href="/contact/">Send a 1‑page summary</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  /* Hide the first H1 inside article content to avoid duplicate titles
     (the page already renders the title in the header above). */
  .article .content > h1:first-of-type { display: none; }
</style>
