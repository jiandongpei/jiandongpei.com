---
import BaseLayout from "@layouts/BaseLayout.astro";
const title = 'Contact';
const description = 'Low‑friction first step for architectural verdicts — formal and minimal.';
---
<BaseLayout {title} {description}>
  <h1>Contact</h1>
  <p class="measure">Send a one‑page summary. No forms. No funnels.</p>

  <h2>What to include (1 page)</h2>
  <ol>
    <li>Landscape: S/4 + BTP runtime(s) + identity surfaces.</li>
    <li>Symptoms by surface/tenant: what works where; what fails where.</li>
    <li>Timeline: go‑live; rollout; recent changes.</li>
    <li>Stakeholders: who owns what today.</li>
    <li>The decision you cannot converge on.</li>
  </ol>

  <h2>Send to</h2>
  <ul>
    <li>Email: <a href="mailto:pei_jiandong@hotmail.com">pei_jiandong@hotmail.com</a></li>
    <li>LinkedIn: <a href="https://www.linkedin.com/in/peijiandong/" target="_blank" rel="noopener">/in/peijiandong</a></li>
  </ul>

  <h2>Expectations</h2>
  <p>I reply with whether the situation matches a boundary failure pattern and, if appropriate, a fixed‑scope next step. No marketing follow‑ups.</p>
</BaseLayout>

