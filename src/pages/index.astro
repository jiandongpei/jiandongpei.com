---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/Button.astro";
import Card from "@components/Card.astro";
import Divider from "@components/Divider.astro";
const title = 'Independent SAP BTP Architect — Boundary Model';
const description = 'Builder-side authority on SAP BTP architecture. Boundary Model, structural diagnosis, and contract-bound verdicts. Not implementation services.';
---
<BaseLayout {title} {description}>
  <!-- Hero -->
  <section class="stack">
    <h1 style="margin-bottom:.25rem;">Independent SAP BTP Architect</h1>
    <p class="lede">Builder‑side authority on SAP BTP. Creator of the Boundary Model. I provide contract‑bound architectural verdicts when extensions fail after go‑live—for example when tenants diverge, identity context drifts, or lifecycle rules shift. I do not offer implementation services; my role is architectural judgment.</p>
    <div style="display:flex; gap:.75rem; flex-wrap:wrap;">
      <Button href="/start-here/" variant="primary">Start here</Button>
      <Button href="/boundary-model/" variant="ghost">Read the Boundary Model</Button>
    </div>
  </section>

  <p class="muted measure">Former SAP platform work across multitenancy, identity propagation, integration boundaries, and lifecycle orchestration. Assessed at runtime boundaries, not in diagrams.</p>

  <Divider />

  <!-- Who this is for -->
  <section class="stack">
    <h2>Who this is for</h2>
    <p class="measure">For leaders and architects whose SAP BTP extensions pass design reviews yet fail in production: behaviors differ by tenant or surface, documentation appears correct, ownership is contested, and runtime does not match intent.</p>
    <p class="measure">Common pattern: it works in isolated tests but fails behind platform surfaces. Tenant behavior diverges. Identity appears correct yet does not hold end‑to‑end. Remediation implies changes to trust, routing, destinations, or roles.</p>
  </section>

  <!-- What I actually do / do not do -->
  <section class="feature">
    <Card eyebrow="Scope" title="What I actually do">
      <ul>
        <li>Diagnose <strong>boundary failures</strong> across runtime, identity, tenant, data, integration, lifecycle.</li>
        <li>Issue a <strong>written verdict</strong>: what must change vs what must not change.</li>
        <li>Re‑establish <strong>jurisdiction</strong>: who owns what, and where.</li>
      </ul>
    </Card>
    <Card eyebrow="Not offered" title="What I do not do">
      <ul>
        <li>No delivery or implementation staffing.</li>
        <li>No ticket execution or staff augmentation.</li>
        <li>No generic consulting.</li>
      </ul>
    </Card>
  </section>

  <Divider />

  <!-- You may need a verdict when... -->
  <section class="stack">
    <h2>You may need a verdict when…</h2>
    <ul>
      <li>Behavior differs by tenant or subaccount.</li>
      <li>Requests succeed in Postman but fail behind AppRouter or Work Zone.</li>
      <li>Incidents appear months after go‑live during rollout or organizational change.</li>
      <li>Remediation would change trust, subdomains, destinations, roles, or tenant routing.</li>
      <li>Ownership is split across teams and no one can issue a decision.</li>
    </ul>
  </section>

  <Divider />

  <!-- Start paths -->
  <section class="feature">
    <div>
      <h2>Start here</h2>
      <p class="measure">Enter at the right depth. For the canonical reference, read the Boundary Model. For patterns and cases, browse Insights.</p>
      <div style="display:flex; gap:.75rem; flex-wrap:wrap;">
        <Button href="/start-here/" variant="primary">Start here</Button>
        <Button href="/insights/" variant="ghost">Insights</Button>
      </div>
    </div>
    <div class="stack">
      <Card eyebrow="Foundation" title="Boundary Model">
        <p class="measure">Canonical definition of six boundaries and why traditional reviews miss these failures.</p>
        <a href="/boundary-model/">Read the model →</a>
      </Card>
      <Card eyebrow="Knowledge" title="Insights">
        <p class="measure">Selected essays on identity, data, integration, and lifecycle failures in SAP BTP.</p>
        <a href="/insights/">Browse essays →</a>
      </Card>
    </div>
  </section>

  <Divider />

  <!-- Work with me -->
  <section class="stack">
    <h2>Work with me</h2>
    <p class="measure">Contract‑bound architectural judgment. Fixed‑scope verdicts, not implementation. See formats and expectations.</p>
    <Button href="/work/" variant="primary">Engagement formats</Button>
  </section>

  <Divider />

  <!-- Closing CTA -->
  <section class="stack">
    <h2>When to call me</h2>
    <p class="measure">If an independent architectural decision is required, send a one‑page summary. The next step is a short, structured assessment and a written scope.</p>
    <div style="display:flex; gap:.75rem; flex-wrap:wrap;">
      <Button href="/when-to-call-me/" variant="ghost">Signals and next steps</Button>
      <Button href="/contact/" variant="primary">Send a 1‑page summary</Button>
    </div>
  </section>
</BaseLayout>
