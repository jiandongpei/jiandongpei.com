---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/Button.astro";
const title = 'Start Here';
const description = 'Orientation for new visitors. Choose the right entry point by situation, boundary, or role.';
---
<BaseLayout {title} {description}>
  <!-- Primary entry -->
  <section class="stack hero compact tight">
    <h1>Start here</h1>
    <p class="lede">Read the Boundary Model first. It defines the six runtime‑visible boundaries and how architectural verdicts are issued.</p>
    <div style="display:flex; gap:.75rem; flex-wrap:wrap;">
      <Button href="/boundary-model/" variant="primary">Read the Boundary Model</Button>
      <Button href="/insights/" variant="ghost">Browse insights</Button>
    </div>
  </section>

  <!-- Secondary guidance -->
  <section class="stack">
    <h2>Explore next</h2>
    <ul>
      <li><strong>Need a decision:</strong> see <a href="/work/">Work With Me</a> or <a href="/when-to-call-me/">When to Call Me</a>.</li>
      <li><strong>Read by boundary:</strong> Runtime · Identity · Tenant · Data · Integration · Lifecycle.</li>
      <li><strong>Core essays:</strong> A003 · A012 · A014 · A019 · A006.</li>
    </ul>
  </section>
</BaseLayout>
