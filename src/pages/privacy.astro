---
import BaseLayout from "@layouts/BaseLayout.astro";
---
<BaseLayout title="Privacy" description="Privacy notice for jiandongpei.com and how inquiries are handled.">
  <h1>Privacy</h1>
  <p class="measure">This site does not use contact forms or account registration.</p>
  <p class="measure">The site may use Cloudflare Web Analytics to understand aggregate traffic patterns. Cloudflare Web Analytics is intended to provide privacy-preserving, aggregated analytics rather than personal tracking.</p>
  <p class="measure">If you contact me by email or LinkedIn, the information you choose to send is handled only for evaluating and responding to the architectural inquiry.</p>
  <p class="measure">If you prefer not to send project detail in an initial message, use the <a href="/intake-template/">intake template</a> and keep the first summary bounded.</p>
</BaseLayout>
