---
import BaseLayout from "@layouts/BaseLayout.astro";
const title = 'Not Found';
const description = 'The page you’re looking for does not exist.';
---
<BaseLayout {title} {description}>
  <section class="stack">
    <h1>Page not found</h1>
    <p class="measure">The page you requested doesn’t exist or has moved.</p>
    <ul>
      <li><a href="/">Go to Home</a></li>
      <li><a href="/insights/">Browse Insights</a></li>
    </ul>
  </section>
</BaseLayout>

