---
// Simple redirect for legacy /library/ link → /insights/
const target = '/insights/';
---
<html lang="en">
  <head>
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Library → Insights</title>
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "62cb45547d1d4cc8855ea2a9b5ee5845"}'></script>
  </head>
  <body>
    <p>Moved to <a href={target}>Insights</a>.</p>
  </body>
  
</html>
