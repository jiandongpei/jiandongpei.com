---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}
const { title = 'Jiandong Pei', description = 'Independent SAP BTP Architect — Boundary Model and architectural verdicts' } = Astro.props as Props;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Jiandong Pei',
    url: 'https://jiandongpei.com',
    jobTitle: 'Independent SAP BTP Architect',
    knowsAbout: [
      'SAP BTP',
      'SAP Business Technology Platform',
      'SAP BTP architecture review',
      'SAP BTP extension audit',
      'SAP BTP post-go-live failure',
      'SAP BTP multitenancy',
      'SAP BTP identity propagation',
      'SAP BTP AppRouter',
      'SAP Build Work Zone',
      'SAP CAP',
      'SAP Clean Core',
      'Boundary Model',
      'Architecture verdict',
    ],
    sameAs: ['https://www.linkedin.com/in/peijiandong/'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    name: 'SAP BTP Architecture Verdict Services',
    url: 'https://jiandongpei.com/work/',
    areaServed: 'Global',
    serviceType: [
      'SAP BTP Architecture Review',
      'SAP BTP Extension Audit',
      'SAP BTP Post-Go-Live Failure Assessment',
      'Boundary Verdict',
    ],
    provider: {
      '@type': 'Person',
      name: 'Jiandong Pei',
      url: 'https://jiandongpei.com',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Jiandong Pei',
    url: 'https://jiandongpei.com',
    description,
  },
];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={`https://jiandongpei.com${Astro.url.pathname}`} />
    <meta name="robots" content="index,follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://jiandongpei.com${Astro.url.pathname}`} />
    <meta property="og:image" content={`https://jiandongpei.com/og-default.svg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

    <!-- Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Source+Serif+4:opsz,wght@8..60,600;8..60,700&display=swap" rel="stylesheet">

    <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "62cb45547d1d4cc8855ea2a9b5ee5845"}'></script>
  </head>
  <body>
    <a href="#main" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;">Skip to content</a>
    <header class="site">
      <div class="container">
        <div class="bar">
          <div class="brand">
            <h1 style="margin: 0; font-size: 1.25rem; font-weight: 700;">
              <a href="/">Jiandong Pei</a>
            </h1>
            <p class="tagline">Independent SAP BTP Architect — Boundary Model</p>
          </div>
          <nav class="nav" aria-label="Primary">
            <Nav />
          </nav>
        </div>
      </div>
    </header>
    <main id="main">
      <div class="container">
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
